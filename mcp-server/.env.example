# Base URL of the URL shortener Express backend.
# For local dev, this is the Express app running on its own port.
# For hosted MCP on Render, set this in the Render dashboard as
# the SHORTENER_API_BASE env var, pointing to your deployed backend.
SHORTENER_API_BASE=http://localhost:5000

# Port for the HTTP transport. Ignored by the stdio transport.
# Render sets this automatically — leave the default for local dev.
PORT=3001
